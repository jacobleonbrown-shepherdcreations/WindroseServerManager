    <sys:String x:Key="Editor.Schema.HttpPort.Name">Dashboard-Port</sys:String>
    <sys:String x:Key="Editor.Schema.HttpPort.Desc">HTTP-Port des Windrose+-Dashboards. Standard: 8780. Muss mit dem eingestellten Port im Manager übereinstimmen.</sys:String>
