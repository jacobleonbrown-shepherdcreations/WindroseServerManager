    <!-- Phase 9 — Opt-in UX (Wizard + Retrofit) -->
    <sys:String x:Key="Wizard.Title">Neuen Server einrichten</sys:String>
    <sys:String x:Key="Wizard.Step1.Label">Installationspfad</sys:String>
    <sys:String x:Key="Wizard.Step2.Label">Windrose+</sys:String>
    <sys:String x:Key="Wizard.Step3.Label">Bestätigung</sys:String>
    <sys:String x:Key="Wizard.Action.Install">Installieren</sys:String>
    <sys:String x:Key="Wizard.Action.Adopt">Übernehmen</sys:String>
    <sys:String x:Key="Wizard.Action.Next">Weiter</sys:String>

    <sys:String x:Key="Wizard.Adoption.DetectedTitle">Bestehende Installation gefunden</sys:String>
    <sys:String x:Key="Wizard.Adoption.DetectedHint">In diesem Ordner liegt bereits eine Windrose-Server-Binary (z. B. aus einer manuellen SteamCMD-Installation). Der Wizard überspringt den SteamCMD-Download und übernimmt die bestehende Installation. Windrose+ kann optional dazuinstalliert werden.</sys:String>
    <sys:String x:Key="Wizard.Adoption.SummaryHint">Bestehende Installation wird übernommen — kein erneuter SteamCMD-Download.</sys:String>
    <sys:String x:Key="Wizard.Adoption.Progress">Bestehende Installation wird übernommen…</sys:String>
    <sys:String x:Key="Wizard.Adoption.DuplicateTitle">Ordner ist bereits registriert</sys:String>
    <sys:String x:Key="Wizard.Adoption.DuplicateHint">Dieser Ordner wird bereits als Server '{0}' verwaltet. Wähle entweder einen anderen Pfad oder verwende den bestehenden Eintrag.</sys:String>
    <sys:String x:Key="Wizard.Adoption.DuplicateHint.Prefix">Bereits registriert als </sys:String>
    <sys:String x:Key="Wizard.Adoption.DuplicateError">Dieser Ordner ist bereits als Server '{0}' registriert.</sys:String>
    <sys:String x:Key="Wizard.Adoption.ServerRunningError">Im Zielordner läuft gerade ein Windrose-Server-Prozess. Bitte stoppe den Server, bevor Windrose+ (re)installiert wird — sonst sind die DLLs gesperrt.</sys:String>

    <sys:String x:Key="Wizard.WindrosePlus.OptIn">Windrose+ installieren</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.OptOut">Ohne Windrose+ fortfahren</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.Disclaimer">Windrose+ ist ein separates MIT-Mod. Es wird in die Server-Dateien installiert und kann jederzeit in den Einstellungen deaktiviert werden.</sys:String>

    <sys:String x:Key="Wizard.WindrosePlus.RconLabel">RCON-Passwort</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.RconTooltip">Wird für Windrose+-Admin-HTTP-Befehle verwendet</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.PortLabel">Dashboard-Port</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.PortHint">Wird automatisch gewählt (18080–18099). In den Einstellungen änderbar.</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.SteamIdLabel">Admin Steam-ID *</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.SteamIdPlaceholder">SteamID64 oder steamcommunity.com/profiles/...</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.SteamIdRequired">Pflichtfeld — wird als Server-Admin eingetragen.</sys:String>

