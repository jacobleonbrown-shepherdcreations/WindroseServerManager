    <!-- Phase 9 — Opt-in UX (Wizard + Retrofit) -->
    <sys:String x:Key="Wizard.Title">Set Up New Server</sys:String>
    <sys:String x:Key="Wizard.Step1.Label">Install Path</sys:String>
    <sys:String x:Key="Wizard.Step2.Label">Windrose+</sys:String>
    <sys:String x:Key="Wizard.Step3.Label">Confirm</sys:String>
    <sys:String x:Key="Wizard.Action.Install">Install</sys:String>
    <sys:String x:Key="Wizard.Action.Adopt">Adopt</sys:String>
    <sys:String x:Key="Wizard.Action.Next">Next</sys:String>

    <sys:String x:Key="Wizard.Adoption.DetectedTitle">Existing installation detected</sys:String>
    <sys:String x:Key="Wizard.Adoption.DetectedHint">A Windrose server binary already lives in this folder (e.g. from a manual SteamCMD install). The wizard will skip the SteamCMD download and adopt the existing installation. Windrose+ can optionally be added on top.</sys:String>
    <sys:String x:Key="Wizard.Adoption.SummaryHint">Existing installation will be adopted — no SteamCMD download will run.</sys:String>
    <sys:String x:Key="Wizard.Adoption.Progress">Adopting existing installation…</sys:String>
    <sys:String x:Key="Wizard.Adoption.DuplicateTitle">Folder is already registered</sys:String>
    <sys:String x:Key="Wizard.Adoption.DuplicateHint">This folder is already managed as server '{0}'. Either pick a different path or use the existing entry.</sys:String>
    <sys:String x:Key="Wizard.Adoption.DuplicateHint.Prefix">Already registered as </sys:String>
    <sys:String x:Key="Wizard.Adoption.DuplicateError">This folder is already registered as server '{0}'.</sys:String>
    <sys:String x:Key="Wizard.Adoption.ServerRunningError">A Windrose server process is currently running in the target folder. Please stop the server before (re)installing Windrose+ — otherwise the DLLs are locked.</sys:String>

    <sys:String x:Key="Wizard.WindrosePlus.OptIn">Install Windrose+</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.OptOut">Continue without Windrose+</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.Disclaimer">Windrose+ is a separate MIT-licensed mod. It installs into your server's game files and can be disabled at any time in Settings.</sys:String>

    <sys:String x:Key="Wizard.WindrosePlus.RconLabel">RCON Password</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.RconTooltip">Used for Windrose+ admin HTTP commands</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.PortLabel">Dashboard Port</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.PortHint">Auto-selected (18080–18099). Can be changed in Settings.</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.SteamIdLabel">Admin Steam ID *</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.SteamIdPlaceholder">SteamID64 or steamcommunity.com/profiles/...</sys:String>
    <sys:String x:Key="Wizard.WindrosePlus.SteamIdRequired">Required — will be set as server admin.</sys:String>

