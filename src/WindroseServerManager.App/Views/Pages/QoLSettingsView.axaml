<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             x:Class="WindroseServerManager.App.Views.Pages.QoLSettingsView"
             x:DataType="vm:QoLSettingsViewModel">
    <Panel>

        <!-- Opt-out empty state -->
        <StackPanel Classes="empty-state" IsVisible="{Binding !IsWindrosePlusActive}">
            <TextBlock Classes="empty-state-icon" Text="&#xE9D5;" />
            <TextBlock Classes="empty-state-title"
                       Text="{DynamicResource QoL.OptOut.Title}" />
            <TextBlock Classes="empty-state-body"
                       Text="{DynamicResource QoL.OptOut.Desc}" />
        </StackPanel>

        <!-- Normal content -->
        <Grid IsVisible="{Binding IsWindrosePlusActive}"
              RowDefinitions="Auto,*,Auto" RowSpacing="16">

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="{DynamicResource QoL.Title}" Classes="page-title" />
                <TextBlock Text="{DynamicResource QoL.Subtitle}" Classes="caption muted" />
            </StackPanel>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16">

                    <!-- Conflict banner -->
                    <Border Classes="card" IsVisible="{Binding HasConflicts}"
                            Background="{DynamicResource BrandErrorBrush}"
                            Opacity="0.15" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xE7BA;"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="18" VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrandErrorBrush}" />
                                <TextBlock Text="{DynamicResource QoL.Conflict.Title}"
                                           Classes="body-emphasis"
                                           Foreground="{DynamicResource BrandErrorBrush}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ActiveConflicts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   Classes="caption" Margin="26,2,0,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- ECONOMY -->
                    <Border Classes="card" Padding="0">
                        <StackPanel>
                            <Border Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                    CornerRadius="8,8,0,0" Padding="16,12">
                                <TextBlock Text="{DynamicResource QoL.Category.Economy}"
                                           Classes="section-header" />
                            </Border>

                            <!-- XP -->
                            <Border BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                                    BorderThickness="0,0,0,1" Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.Xp.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.Xp.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding XpMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding XpMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding XpMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Loot -->
                            <Border BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                                    BorderThickness="0,0,0,1" Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.Loot.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.Loot.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding LootMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding LootMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding LootMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Craft Cost -->
                            <Border Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.CraftCost.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.CraftCost.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding CraftCostMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding CraftCostMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding CraftCostMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- FARMING -->
                    <Border Classes="card" Padding="0">
                        <StackPanel>
                            <Border Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                    CornerRadius="8,8,0,0" Padding="16,12">
                                <TextBlock Text="{DynamicResource QoL.Category.Farming}"
                                           Classes="section-header" />
                            </Border>

                            <!-- Crop Speed -->
                            <Border BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                                    BorderThickness="0,0,0,1" Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.CropSpeed.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.CropSpeed.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding CropSpeedMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding CropSpeedMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding CropSpeedMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Cooking Speed -->
                            <Border BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                                    BorderThickness="0,0,0,1" Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.CookingSpeed.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.CookingSpeed.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding CookingSpeedMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding CookingSpeedMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding CookingSpeedMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Harvest Yield -->
                            <Border Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.HarvestYield.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.HarvestYield.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding HarvestYieldMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding HarvestYieldMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding HarvestYieldMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- INVENTORY (danger zone) -->
                    <Border Classes="card" Padding="0">
                        <StackPanel>
                            <Border Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                    CornerRadius="8,8,0,0" Padding="16,12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{DynamicResource QoL.Category.Inventory}"
                                               Classes="section-header" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="&#xE7BA;"
                                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrandAmberBrush}" />
                                        <TextBlock Classes="caption"
                                                   Foreground="{DynamicResource BrandAmberBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{DynamicResource QoL.Inventory.DangerWarning}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Stack Size -->
                            <Border BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                                    BorderThickness="0,0,0,1" Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.StackSize.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.StackSize.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding StackSizeMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding StackSizeMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding StackSizeMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Inventory Size -->
                            <Border BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                                    BorderThickness="0,0,0,1" Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.InventorySize.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.InventorySize.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding InventorySizeMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding InventorySizeMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding InventorySizeMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Weight -->
                            <Border Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.Weight.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.Weight.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding WeightMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding WeightMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding WeightMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- CHARACTER -->
                    <Border Classes="card" Padding="0">
                        <StackPanel>
                            <Border Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                    CornerRadius="8,8,0,0" Padding="16,12">
                                <TextBlock Text="{DynamicResource QoL.Category.Character}"
                                           Classes="section-header" />
                            </Border>

                            <!-- Points Per Level -->
                            <Border Padding="16,14">
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Classes="body-emphasis"
                                                       Text="{DynamicResource QoL.PointsPerLevel.Name}" />
                                            <TextBlock Classes="caption muted" TextWrapping="Wrap"
                                                       Text="{DynamicResource QoL.PointsPerLevel.Desc}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                CornerRadius="6" Padding="10,4"
                                                VerticalAlignment="Center" MinWidth="64">
                                            <TextBlock Text="{Binding PointsPerLevelMultiplier, StringFormat={}{0:F1}x}"
                                                       FontFamily="Consolas,Courier New"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandAmberBrush}"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,84" ColumnSpacing="10">
                                        <Slider Grid.Column="0" Value="{Binding PointsPerLevelMultiplier}"
                                                Minimum="0.1" Maximum="10" TickFrequency="0.1"
                                                SmallChange="0.1" LargeChange="0.5" />
                                        <TextBox Grid.Column="1" Classes="mono"
                                                 Text="{Binding PointsPerLevelMultiplier, StringFormat={}{0:F1}}"
                                                 HorizontalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Classes="subtle"
                        Content="{DynamicResource QoL.ResetAll}"
                        Command="{Binding ResetAllCommand}" />
                <Button Grid.Column="2" Classes="primary"
                        Content="{DynamicResource QoL.Save}"
                        Command="{Binding SaveCommand}" />
            </Grid>

        </Grid><!-- /Normal content -->

    </Panel>
</UserControl>
